<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/clNotificationRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_notification_green"
    android:padding="16dp">

    <!-- Icon background circle -->
    <View
        android:id="@+id/vIconBg"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="#1A16B88A"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/ivNotificationIcon"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:src="@drawable/ic_success_check"
        app:layout_constraintBottom_toBottomOf="@+id/vIconBg"
        app:layout_constraintEnd_toEndOf="@+id/vIconBg"
        app:layout_constraintStart_toStartOf="@+id/vIconBg"
        app:layout_constraintTop_toTopOf="@+id/vIconBg"
        app:tint="#16B88A" />

    <TextView
        android:id="@+id/tvNotificationTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:text="Scan Complete"
        android:textColor="#1E293B"
        android:textSize="15sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/vIconBg"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvNotificationMessage"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="4dp"
        android:lineSpacingExtra="2dp"
        android:text="Your Organic Granola scan results are ready to view"
        android:textColor="#475569"
        android:textSize="13sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/vIconBg"
        app:layout_constraintTop_toBottomOf="@+id/tvNotificationTitle" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintStart_toEndOf="@+id/vIconBg"
        app:layout_constraintTop_toBottomOf="@+id/tvNotificationMessage">

        <ImageView
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:src="@drawable/ic_clock"
            app:tint="#94A3B8" />

        <TextView
            android:id="@+id/tvNotificationTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="5 HOURS AGO"
            android:textColor="#94A3B8"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
